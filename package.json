{
  "name": "shlep",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "shlep (SHL Encrypted Proxy) — schlep your health data anywhere: blind, revocable SMART Health Links backed by any cloud object store.",
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "test:emulators": "bash scripts/test-emulators.sh",
    "gen:llms": "bun run scripts/gen-llms.ts",
    "build:site": "bun run scripts/build-site.ts",
    "typecheck": "bunx tsc --noEmit && bunx tsc -p tsconfig.standard.json"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0",
    "esbuild": "^0.24.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@google-cloud/storage": "^7.14.0",
    "@azure/storage-blob": "^12.26.0"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@google-cloud/storage": "^7.0.0",
    "@azure/storage-blob": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "@aws-sdk/client-s3": { "optional": true },
    "@aws-sdk/s3-request-presigner": { "optional": true },
    "@google-cloud/storage": { "optional": true },
    "@azure/storage-blob": { "optional": true }
  }
}
